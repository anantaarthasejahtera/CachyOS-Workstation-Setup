# EditorConfig helps maintain consistent coding styles for multiple developers
# and editors. See https://editorconfig.org/

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

# Bash scripts
[*.sh]
indent_style = space
indent_size = 4

# Markdown files
[*.md]
trim_trailing_whitespace = false
indent_style = space
indent_size = 2

# Configuration files
[*.{json,yml,yaml,conf}]
indent_style = space
indent_size = 2
